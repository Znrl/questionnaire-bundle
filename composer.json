{
    "name": "znrl/questionnaire-bundle",
    "version": "0.0.1-dev",
    "description": "Contao 5 Questionnaire Bundle. Create score based questionnaires.",
    "type": "contao-bundle",
    "license": "LGPL-3.0-or-later",
    "website" : "https://www.znrl.de/",
    "authors": [
        {
            "name": "Lorenz Ketterer",
            "homepage": "https://www.znrl.de/",
            "role":"Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "contao/core-bundle": "^5.3",
        "codefog/contao-haste": "^5.4"
    },
    "autoload":{
        "psr-4": {
            "Znrl\\QuestionnaireBundle\\": "src/"
        },
        "classmap": [
            "contao/"
        ],
        "exclude-from-classmap": [
            "contao/config/",
            "contao/dca/",
            "contao/languages/",
            "contao/templates/"
        ]
    },
    "scripts": {
        "rector": "vendor/bin/rector -p --ansi",
        "rector-dry": "vendor/bin/rector -p --dryrun --ansi",
        "check-cs": "vendor/bin/ecs check --ansi",
        "fix-cs": "vendor/bin/ecs check --fix --ansi"
    },
    "extra":{
        "contao-manager-plugin": "Znrl\\QuestionnaireBundle\\ContaoManager\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "php-http/discovery": true,
            "contao/manager-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "conflict": {
        "contao/manager-plugin": "<2.0 || >=3.0"
    },
    "require-dev": {
        "contao/manager-plugin": "@stable",
        "contao/easy-coding-standard": "@stable",
        "rector/rector": "@stable",
        "phpstan/phpstan": "@stable",
        "contao/contao-rector": "dev-main"
    }
}
