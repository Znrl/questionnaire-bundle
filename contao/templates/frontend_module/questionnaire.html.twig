{% extends "@Contao/frontend_module/_base.html.twig" %}

{% block content %}

  {% if result %}

    <h3>{{ result_headline }}</h3>

    {{ result_text|raw }}

    {% if send_form and mail_sent === false %}

      {{ send_form|raw }}

    {% endif %}

  {% else %}

    {{ form|raw }}

  {% endif %}

{% endblock %}